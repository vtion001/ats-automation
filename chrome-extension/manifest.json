{
  "manifest_version": 3,
  "name": "ATS Automation",
  "version": "2.3.0",
  "description": "BPO workflow automation - CTM call monitoring + audio capture",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabCapture",
    "notifications"
  ],
  "host_permissions": [
    "*://*.calltrackingmetrics.com/*",
    "*://*.zoho.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Toggle audio recording"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "src/lib/core.js",
        "src/services/ctm-service.js",
        "src/call-monitor.js",
        "src/main.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.calltrackingmetrics.com/calls/phone*"
      ],
      "js": [
        "content-scripts/ctm-monitor.js",
        "content-scripts/overlay.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "content-scripts/console-interceptor.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
