{
  "manifest_version": 3,
  "name": "ATS Automation",
  "version": "2.2.0",
  "description": "BPO client workflow automation - CTM call monitoring",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.calltrackingmetrics.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "src/lib/core.js",
        "src/services/ctm-service.js",
        "src/modules/call-monitor.js",
        "src/main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
