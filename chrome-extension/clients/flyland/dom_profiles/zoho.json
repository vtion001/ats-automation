{
  "system": "zoho",
  "client": "flyland",
  "url_pattern": "*.zoho.com/mail",
  "variant": "zoho_mail",
  "selectors": {
    "chat_container": ".chat-messages, .message-list, .zsiq_msgcnt",
    "message_input": "textarea[placeholder*='Type'], .composer-input, [contenteditable='true']",
    "customer_message": ".message-in, .zsiq_message, .customer-msg",
    "agent_message": ".message-out, .agent-msg",
    "sender_name": ".sender-name, .msg-sender",
    "timestamp": ".msg-time, .timestamp"
  },
  "reply_template_selectors": {
    "quick_reply": ".quick-reply-btn, .canned-response",
    "template_menu": ".template-dropdown, .reply-templates"
  },
  "notes": "ZOHO Mail for Flyland - not SalesIQ"
}
