{
  "system": "salesforce_lightning",
  "client": "tbt",
  "url_pattern": "*.lightning.force.com",
  "selectors": {
    "lead_queue": ".forceTable, .slds-table",
    "call_button": "[title='Call'], button[title*='Call']",
    "phone": "[data-field-name='Phone'], .phone-field",
    "lead_status": "[data-field-name='Status']",
    "last_activity": "[data-field-name='LastActivityDate']"
  },
  "search_url_pattern": "/lightning/setup/FindRecords?term={phone}",
  "notes": "TBT uses SF Lightning ONLY - no CTM"
}
