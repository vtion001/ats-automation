# ATS Automation - Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (get from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ATS Server Configuration
ATS_API_KEY=your_ats_api_key_here

# Optional: ATS Server URL (if using remote server)
# ATS_SERVER_URL=http://localhost:8000

# Remote Log Viewer URL (for remote monitoring)
# Set this to enable remote log viewing from your Mac
# REMOTE_LOG_URL=https://your-tunnel.trycloudflare.com
