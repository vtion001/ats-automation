{
  "client": "takami",
  "name": "Takahami Medical",
  "industry": "Medical Billing",
  "qualification_criteria": {
    "hot_lead": {
      "keywords": ["interested", "outsource", "billing", "services", "save", "cost", "improve", "revenue"],
      "score_weight": 30,
      "description": "Interested in billing services"
    },
    "warm_lead": {
      "keywords": ["information", "details", "pricing", "how does it work", "capabilities"],
      "score_weight": 15,
      "description": "Needs more information"
    },
    "urgent": {
      "keywords": ["asap", "immediately", "urgent", "deadline", "compliance", "audit"],
      "score_weight": 25,
      "description": "Urgent compliance or billing issue"
    },
    "provider": {
      "keywords": ["physician", "doctor", "practice", "clinic", "hospital", "provider"],
      "score_weight": 20,
      "description": "Healthcare provider"
    },
    "unqualified": {
      "keywords": ["not interested", "no thank", "wrong number", "in house", "already doing"],
      "score_weight": -30,
      "description": "Not interested or already has service"
    }
  },
  "departments": {
    "sales": {
      "name": "Sales",
      "keywords": ["interested", "outsource", "pricing", "demo"],
      "transfer_trigger": "score >= 50"
    },
    "billing_support": {
      "name": "Billing Support",
      "keywords": ["claim", "denial", "payment", "issue", "problem"],
      "transfer_trigger": "has billing issue"
    },
    "compliance": {
      "name": "Compliance",
      "keywords": ["compliance", "audit", "regulation", "hipaa"],
      "transfer_trigger": "has compliance keywords"
    }
  },
  "qualification_thresholds": {
    "hot": 60,
    "warm": 30,
    "cold": 0
  }
}
