{
  "sf_to_ctm_mapping": {
    "Phone": "phone_number",
    "Name": "caller_name",
    "Email": "caller_email",
    "Status": "disposition_status"
  },
  "ctm_to_sf_mapping": {
    "phone-field": "Phone",
    "caller-name": "Name",
    "disposition": "Status"
  },
  "dom_selectors": {
    "ctm": {
      "call_notification": [".caller-id", ".call-info"],
      "phone_number": ["#phone-field", ".phone-input"],
      "disposition": ["#disposition", ".disposition-select"]
    },
    "salesforce": {
      "account_name": [".forceCommunityRecordName", ".slds-truncate"],
      "phone": ["[data-field-name='Phone']", ".phone-field"],
      "email": ["[data-field-name='Email']", ".email-field"]
    }
  },
  "automations": {
    "ctm_sf_auto_access": {
      "enabled": true,
      "trigger": "incoming_call",
      "action": "open_sf_account"
    },
    "auto_note_generator": {
      "enabled": true,
      "trigger": "disposition_selected",
      "dispositions": ["unqualified", "duplicate"]
    }
  }
}
