{
  "client_name": "flyland",
  "display_name": "Flyland Recovery",
  "description": "Addiction counseling center - handles mixed calls/chats",
  "systems": {
    "ctm": {
      "name": "Call Tracking Metrics",
      "url_pattern": "*.calltrackingmetrics.co",
      "enabled": true
    },
    "salesforce": {
      "name": "Salesforce",
      "url_pattern": "*.flyland.my.salesforce.com",
      "enabled": true,
      "filters": {
        "record_type": "Account"
      }
    },
    "zoho": {
      "name": "ZOHO Mail",
      "url_pattern": "*.zoho.com/mail",
      "enabled": true
    }
  },
  "automations": {
    "ctm_sf_auto_access": {
      "enabled": true,
      "priority": "HIGH",
      "phase": 1,
      "delay_ms": 500,
      "timeout_ms": 5000
    },
    "auto_note_generator": {
      "enabled": true,
      "priority": "HIGH",
      "phase": 1,
      "confidence_threshold": 0.7,
      "dispositions": ["unqualified", "duplicate"]
    },
    "chat_reply_suggester": {
      "enabled": true,
      "priority": "MEDIUM",
      "phase": 2
    },
    "wrapup_sync": {
      "enabled": false,
      "priority": "MEDIUM",
      "phase": 2
    }
  },
  "logging": {
    "level": "INFO",
    "save_to_file": true,
    "sync_to_server": true
  },
  "nlp": {
    "enabled": true,
    "model": "distilbert",
    "confidence_threshold": 0.7
  }
}
