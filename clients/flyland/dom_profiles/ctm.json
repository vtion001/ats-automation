{
  "system": "ctm",
  "client": "flyland",
  "selectors": {
    "call_notification": ".caller-id, .call-info, [class*='caller']",
    "phone_number": "#phone-field, .phone-input, [data-field='phone']",
    "caller_name": ".caller-name, .contact-name",
    "disposition_dropdown": "#disposition, .disposition-select, select[name='disposition']",
    "wrapup_form": ".wrapup-form, #wrapup",
    "call_status": ".call-status, .call-state"
  },
  "event_selectors": {
    "incoming_call": ".incoming-call, .call-ringing",
    "call_ended": ".call-ended, .hangup",
    "wrapup_start": ".show-wrapup, #wrapup-display"
  },
  "selectors_priority": [
    "[data-testid='phone']",
    "[class*='phone']",
    "#phone",
    "input[type='tel']"
  ],
  "notes": "CTM selectors for Flyland Recovery - phone field is primary trigger"
}
